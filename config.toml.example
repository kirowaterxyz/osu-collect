# put this in ~/.config/osu-collect/config.toml (Linux/macOS)
# or %APPDATA%\osu-collect\config.toml (Windows)
# every key is optional — missing keys fall back to the defaults shown here

[mirror]
# built-in beatmap mirrors; enable any combination (all on by default)
nerinyan = true
osu_direct = true
sayobot = true
nekoha = true

# optional custom beatmap mirrors; each template must contain {id}
# tried after the built-ins, in list order (legacy single `url = "..."` is still read)
# urls = ["https://example.com/d/{id}", "https://mirror.example.net/d/{id}"]

# the official osu! mirror is enabled by logging in on the config tab
# (credentials are stored in auth.json next to ts file, not here)

[download]
# parallel downloads; defaults to your CPU core count when unset
# values above 50 trigger a warning — 20 or less avoids rate limiting
# concurrent = 8

# include beatmap videos in downloads (uses each mirror's no-video template when false)
video = true

# .osz integrity check: "off", "magic" (ZIP header, default) or "eocd" (full footer scan)
archive_validation = "magic"

# when a new download overlaps previously failed maps:
# "ask" (prompt, default), "yes" (always retry), "no" (skip silently)
retry_failed_on_download = "ask"

[display]
# "full" (truecolor, default) or "compatible" (xterm-256/16-color).
# Omit this key entirely to auto-detect from the terminal's color depth on first run.
theme = "full"
# vim navigation keymap (hjkl move, gg/G top/bottom, ctrl+u/d page, i/a edit).
# off by default; also toggleable live on the config tab.
vim_keys = false

[logging]
# structured logging is disabled by default, set to true to enable tracing output
enabled = false

# supported levels: error, warn, info, debug, trace
level = "info"

# console format: "compact" (default) or "pretty"
format = "compact"

# optional directory for rolled JSON log files
# file_dir = "/home/user/.local/share/osu-collect/logs"

# [recent] is managed automatically (last collection + download dir) — no need to edit it
