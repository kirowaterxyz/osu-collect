# put this in ~/.config/osu-collect/config.toml to use it

[mirror]
# Select any combination of supported mirrors
nerinyan = true
osu_direct = false
sayobot = false

# use the official osu! API v2 as a download source
official = false

# Optional custom mirror template (must contain {id})
# url = "https://example.com/d/{id}"

[official]
# osu! oauth credentials for login or client-credentials downloads
# client_id = ""
# client_secret = ""

[download]
# autoskip existing files without prompting (default: false)
skip_existing = false

# concurrent downloads
concurrent = 6

# download beatmapsets without video if the mirror supports it
no_video = false

# check the ZIP EOCD footer to verify .osz integrity
verify_zip_eocd = false

[logging]
# structured logging is disabled by default, set to true to enable tracing output
enabled = false

# supported levels: error, warn, info, debug, trace
level = "info"

# console format: "compact" (default) or "pretty"
format = "compact"

# optional directory for rolled JSON log files
# file_dir = "/home/user/.local/share/osu-collect/logs"
